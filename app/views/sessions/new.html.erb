<div class="mx-auto max-w-[480px] w-full p-6 bg-card border-border border rounded-lg mt-48">
  <% if alert = flash[:alert] %>
    <p class="py-3 px-4 bg-red-100 text-red-600 font-medium rounded-lg text-center" id="alert">
      <%= alert %>
    </p>
  <% end %>

  <% if notice = flash[:notice] %>
    <p class="py-3 px-4 bg-green-100 text-green-600 font-medium rounded-lg text-center" id="notice">
      <%= notice %>
    </p>
  <% end %>

  <h1 class="font-extrabold text-3xl text-gray-900 text-center mb-6">Sign in</h1>

  <%= form_with url: sessions_path, class: "space-y-5" do |form| %>
    <div>
      <%= form.label :email_address, "Email Address", class: "block text-gray-700 font-medium" %>
      <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", placeholder: "Enter your email address", value: params[:email_address], class: "block w-full px-4 py-3 mt-2 text-gray-900 border rounded-lg shadow-sm border-gray-300 focus:ring-2 focus:ring-blue-500 focus:outline-none" %>
    </div>

    <div>
      <%= form.label :password, "Password", class: "block text-gray-700 font-medium" %>
      <%= form.password_field :password, required: true, autocomplete: "current-password", placeholder: "Enter your password", maxlength: 72, class: "block w-full px-4 py-3 mt-2 text-gray-900 border rounded-lg shadow-sm border-gray-300 focus:ring-2 focus:ring-blue-500 focus:outline-none" %>
    </div>

    <div class="flex items-center justify-between mt-8">
      <%= form.submit "Sign in", class: "w-full bg-blue-600 hover:bg-blue-500 text-white font-medium py-3 rounded-lg text-center shadow-sm transition duration-300" %>
    </div>
  <% end %>

  <div class="text-center mt-4 text-sm text-gray-600">
    <%= link_to "Forgot password?", new_password_path, class: "text-blue-600 hover:text-blue-500 font-medium" %>
  </div>

  <div class="text-center mt-2 text-sm text-gray-600">
    Don't have an account?
    <%= link_to "Sign up", new_user_path, class: "text-blue-600 hover:text-blue-500 font-medium" %>
  </div>
</div>
